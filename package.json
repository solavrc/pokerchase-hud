{
  "name": "pokerchase-hud",
  "version": "4.1.0",
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "postbuild": "zip -r extension.zip dist/ icons/ manifest.json",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "validate-schema": "tsx src/tools/validate-schemas.ts",
    "schema-diff": "tsx src/tools/detect-schema-diff.ts",
    "ccusage": "npx ccusage@latest",
    "firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules",
    "firebase:deploy:indexes": "firebase deploy --only firestore:indexes",
    "firebase:emulators": "firebase emulators:start --only firestore"
  },
  "type": "module",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/browserify": "^12.0.40",
    "@types/chrome": "^0.1.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-window": "^2.0.0",
    "buffer": "^6.0.3",
    "esbuild": "^0.27.0",
    "esbuild-plugin-tsc": "^0.5.0",
    "events": "^3.3.0",
    "fake-indexeddb": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.5",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.4"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@extend-chrome/storage": "^1.5.0",
    "@msgpack/msgpack": "^3.0.0-beta2",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "dexie": "^4.0.4",
    "firebase": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-window": "^2.0.0",
    "zod": "^4.0.5"
  }
}
